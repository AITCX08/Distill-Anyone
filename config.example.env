# ============================================================
# Distill-Anyone 配置文件
# 复制此文件为 .env 并填写实际值
# ============================================================

# ---- B站Cookie配置 ----
# 从浏览器开发者工具 (F12) → Application → Cookies 获取
# 详细获取方法请参考 README.md
BILIBILI_SESSDATA=your_sessdata_here
BILIBILI_BILI_JCT=your_bili_jct_here
BILIBILI_BUVID3=your_buvid3_here

# ---- UP主配置 ----
# UP主的UID（在UP主主页URL中可以找到）
UP_UID=12345678

# ---- LLM 提供商选择 ----
# 可选值: claude / openai / qwen / deepseek
LLM_PROVIDER=claude

# ---- Claude API 配置 ----
# 从 https://console.anthropic.com/ 获取
ANTHROPIC_API_KEY=your_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ---- OpenAI API 配置 ----
# 从 https://platform.openai.com/ 获取
OPENAI_API_KEY=your_openai_api_key_here
# API Base URL（支持兼容接口，如自部署或第三方代理）
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# ---- 通义千问 Qwen 配置（阿里云 DashScope）----
# 从 https://dashscope.console.aliyun.com/ 获取 API Key
QWEN_API_KEY=your_dashscope_api_key_here
# DashScope OpenAI 兼容接口地址（一般无需修改）
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# 可选模型: qwen3-235b-a22b / qwen3-30b-a3b / qwen-turbo-latest 等
QWEN_MODEL=qwen3-235b-a22b

# ---- DeepSeek 配置 ----
# 从 https://platform.deepseek.com/ 获取 API Key
DEEPSEEK_API_KEY=your_deepseek_api_key_here
# DeepSeek API 地址（一般无需修改）
DEEPSEEK_BASE_URL=https://api.deepseek.com
# 可选模型: deepseek-reasoner (R1) / deepseek-chat (V3) 等
DEEPSEEK_MODEL=deepseek-reasoner

# ---- FunASR 配置 ----
# ASR模型名称（默认 paraformer-zh）
FUNASR_MODEL=paraformer-zh
# VAD模型（语音活动检测）
FUNASR_VAD_MODEL=fsmn-vad
# 标点恢复模型
FUNASR_PUNC_MODEL=ct-punc

# ---- 目录配置 ----
DATA_DIR=./data
OUTPUT_DIR=./output
